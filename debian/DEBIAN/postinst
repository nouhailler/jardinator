#!/bin/bash
set -e

# Mettre à jour la base de données des applications .desktop
if command -v update-desktop-database &>/dev/null; then
    update-desktop-database /usr/share/applications || true
fi

# Mettre à jour le cache des icônes
if command -v gtk-update-icon-cache &>/dev/null; then
    gtk-update-icon-cache /usr/share/pixmaps || true
fi

echo ""
echo "✅  Jardinator v2.1.0 installé avec succès !"
echo ""
echo "   Lancer : jardinator"
echo "   Ou depuis le menu : Applications → Éducation → Jardinator"
echo ""
echo "   L'application s'ouvre dans votre navigateur sur http://localhost:8765"
echo ""

exit 0
