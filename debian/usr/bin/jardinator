#!/bin/bash
# Jardinator — lanceur de l'application web locale
# Démarre un serveur HTTP sur localhost:8765 et ouvre le navigateur

APP_DIR="/usr/lib/jardinator"
PORT=8765
PIDFILE="/tmp/jardinator-server.pid"

# Vérifier si le serveur tourne déjà
if [ -f "$PIDFILE" ] && kill -0 "$(cat "$PIDFILE")" 2>/dev/null; then
    xdg-open "http://localhost:$PORT"
    exit 0
fi

# Démarrer le serveur HTTP Python en arrière-plan
cd "$APP_DIR"
python3 -m http.server "$PORT" --bind 127.0.0.1 \
    >/tmp/jardinator-server.log 2>&1 &
echo $! > "$PIDFILE"

# Attendre que le serveur soit prêt (max 3s)
for i in 1 2 3 4 5 6; do
    sleep 0.5
    if python3 -c "import urllib.request; urllib.request.urlopen('http://localhost:$PORT')" 2>/dev/null; then
        break
    fi
done

# Ouvrir dans le navigateur par défaut
xdg-open "http://localhost:$PORT"
